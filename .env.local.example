# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Shopify Admin API
SHOPIFY_TOKEN=your_shopify_token_here
SHOPIFY_STORE=yourstore.myshopify.com

# Meta Ads API
META_TOKEN=your_meta_token_here
META_ACCOUNT_ID=your_meta_account_id_here

# lexoffice
LEXOFFICE_TOKEN=your_lexoffice_token_here

# Gmail OAuth2
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REFRESH_TOKEN=your_google_refresh_token_here

# Anthropic — Claude API (CFO + Tax agents + Cost Tracker)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_INPUT_PRICE_USD=0.000003
CLAUDE_OUTPUT_PRICE_USD=0.000015
NEXT_PUBLIC_USD_EUR_RATE=0.93
